DEEPGRAM_API_KEY=
# Optional: external LLM that writes the post-call feedback report from the
# transcript. Without it, the report falls back to in-session assessments.
GROQ_API_KEY=
# EVAL_MODEL=openai/gpt-oss-120b
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgres://liveai:liveai@localhost:5433/liveai
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Interview length guardrails (milliseconds). All optional — the values below
# are the built-in defaults; uncomment to override. See backend/config.js.
# Soft nudge: steer the agent to start closing.
# SOFT_WRAP_MS=420000
# After the soft nudge, re-send a firm "wrap up now" on this interval.
# POST_NUDGE_MS=60000
# Hard cap (Vapi's maxDurationSeconds analog): server speaks a fixed closing
# line and ends. Bounds total call length no matter how the agent behaves.
# MAX_DURATION_MS=660000
# Safety net if the injected goodbye never produces an AgentAudioDone.
# END_CALL_FALLBACK_MS=12000
